{
  "name": "@um7a/config-loader",
  "version": "1.0.4",
  "description": "Configuration loader for Deno applications.",
  "license": "BSD-3-Clause",
  "exports": "./src/config_loader.ts",
  "publish": {
    "include": [
      "README.md",
      "LICENSE",
      "src/config_loader.ts"
    ]
  },
  "tasks": {
    "check": "deno fmt --check deno.json src/ tests/ README.md && deno lint && deno check src/ && deno test --allow-read --allow-write --allow-env",
    "publish:dry": "deno publish --dry-run"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/yaml": "jsr:@std/yaml@1"
  }
}
